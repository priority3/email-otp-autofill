{
  "manifest_version": 3,
  "key": "",
  "name": "Email OTP Autofill",
  "version": "0.1.4",
  "description": "Fetch OTP codes from an agent (QQ Mail / Outlook) and fill into the current page.",
  "permissions": ["storage", "activeTab", "tabs", "alarms", "identity"],
  "host_permissions": ["https://otp.razet.me/*", "http://127.0.0.1:17373/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Email OTP Autofill",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "fill_otp": {
      "suggested_key": {
        "default": "Ctrl+Shift+Period",
        "mac": "Command+Shift+Period"
      },
      "description": "Fill OTP from email"
    }
  }
}
