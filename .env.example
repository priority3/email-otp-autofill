# Email OTP Autofill — server environment
#
# Copy to .env (git-ignored) and fill in:
#   cp .env.example .env
# Then run:  docker compose up -d                       (agent only)
#       or:  docker compose --profile cloudflare up -d  (expose via Tunnel)
#
# The agent is always a multi-tenant service: users log in with their own
# account; the extension only points at the server URL. Only two secrets matter.

# ── Master key for at-rest encryption of email credentials (REQUIRED) ───────
# Encrypts stored email auth codes / app passwords (AES-256-GCM, scrypt). Read
# only from the environment, never written to disk. Keep it STABLE — losing or
# changing it makes existing stored credentials unrecoverable.
# Generate:  openssl rand -base64 32
OTP_AGENT_MASTER_KEY=

# ── Admin token — guards /admin panel + /v1/admin/* API (REQUIRED for admin) ─
# Visit https://<your-domain>/admin and log in with this value. End users
# authenticate with their own account, NOT this token. Unset = admin disabled.
# Generate:  openssl rand -base64 24
OTP_ADMIN_TOKEN=

# ── Cloudflare Tunnel token (only with `--profile cloudflare`) ──────────────
CF_TUNNEL_TOKEN=
