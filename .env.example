# Email OTP Autofill — self-hosting environment template
#
# Copy to .env (which is git-ignored) and fill in your values:
#   cp .env.example .env
#
# Then run:  docker compose up -d   (add `--profile cloudflare` to expose via Tunnel)

# ── Master key for at-rest encryption of email credentials ──────────────────
# REQUIRED for any networked / server deployment. Without it, the email auth
# codes / app passwords are stored in PLAINTEXT in data/secrets.json.
# Generate a strong random value:
#   openssl rand -base64 32
OTP_AGENT_MASTER_KEY=

# ── API key required by the extension when the agent is reachable over a domain ─
# Strongly recommended for any public exposure. Set the SAME value in the
# extension's Settings → Agent API Key. Generate one with:
#   openssl rand -base64 24
OTP_AGENT_API_KEY=

# ── Cloudflare Tunnel token (only needed with `--profile cloudflare`) ───────
# Fetch from the Cloudflare dashboard / API as the tunnel run token.
CF_TUNNEL_TOKEN=
